# Copy to .env and fill in if you use the optional live clients.
# The default offline demo and the full test suite need NONE of these.

# Optional: a local Ollama endpoint for the free local client (demo.py --local / --hybrid).
# OLLAMA_HOST=http://localhost:11434

# The live client (claude_cli_client) shells out to the `claude` CLI on your PATH and
# needs no key here; authenticate the CLI separately.
